{
  "info": {
    "name": "Tech Challenge Fase 03",
    "description": "Complete API collection for all microservices: user-service (8081), payment-service (8082), order-service (8080)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "user_service_url", "value": "http://localhost:8081" },
    { "key": "order_service_url", "value": "http://localhost:8080" },
    { "key": "payment_service_url", "value": "http://localhost:8082" },
    { "key": "auth_token", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "customer_id", "value": "1" },
    { "key": "restaurant_id", "value": "1" },
    { "key": "menu_item_id", "value": "1" },
    { "key": "order_id", "value": "1" }
  ],
  "item": [
    {
      "name": "User Service",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Register",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "url": { "raw": "{{user_service_url}}/auth/register" },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"João Fontes\",\n  \"email\": \"joao@email.com\",\n  \"password\": \"senha1234\",\n  \"role\": \"ROLE_CUSTOMER\"\n}"
                }
              }
            },
            {
              "name": "Register Restaurant Owner",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "url": { "raw": "{{user_service_url}}/auth/register" },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Dono Restaurante\",\n  \"email\": \"dono@restaurante.com\",\n  \"password\": \"senha1234\",\n  \"role\": \"ROLE_RESTAURANT_OWNER\"\n}"
                }
              }
            },
            {
              "name": "Login",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var jsonData = pm.response.json();",
                      "if (jsonData.token) {",
                      "  pm.collectionVariables.set('auth_token', jsonData.token);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "url": { "raw": "{{user_service_url}}/auth/login" },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"joao@email.com\",\n  \"password\": \"senha1234\"\n}"
                }
              }
            }
          ]
        },
        {
          "name": "Users",
          "item": [
            {
              "name": "Get All Users",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{auth_token}}" }
                ],
                "url": { "raw": "{{user_service_url}}/users" }
              }
            },
            {
              "name": "Get User By ID",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{auth_token}}" }
                ],
                "url": { "raw": "{{user_service_url}}/users/{{user_id}}" }
              }
            },
            {
              "name": "Update User",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{auth_token}}" }
                ],
                "url": { "raw": "{{user_service_url}}/users/{{user_id}}" },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"João Fontes Atualizado\",\n  \"email\": \"joao.novo@email.com\",\n  \"password\": \"novaSenha1234\"\n}"
                }
              }
            },
            {
              "name": "Delete User",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{auth_token}}" }
                ],
                "url": { "raw": "{{user_service_url}}/users/{{user_id}}" }
              }
            }
          ]
        }
      ]
    },
    {
