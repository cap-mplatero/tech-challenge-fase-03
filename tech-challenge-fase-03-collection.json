        },
        {
          "name": "Orders",
          "item": [
            {
              "name": "Create Order",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{auth_token}}" }
                ],
                "url": { "raw": "{{order_service_url}}/api/orders" },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"restaurantId\": 1,\n  \"menuItemQuantities\": {\n    \"1\": 2,\n    \"2\": 1,\n    \"3\": 3\n  }\n}"
                }
              }
            },
            {
              "name": "Get Order By ID",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{auth_token}}" }
                ],
                "url": { "raw": "{{order_service_url}}/api/orders/{{order_id}}" }
              }
            },
            {
              "name": "Get My Orders",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{auth_token}}" }
                ],
                "url": { "raw": "{{order_service_url}}/api/orders" }
              }
            },
            {
              "name": "Get Orders By Status",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{auth_token}}" }
                ],
                "url": { "raw": "{{order_service_url}}/api/orders/status/PENDING" }
              }
            },
            {
              "name": "Get Orders By Restaurant",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{auth_token}}" }
                ],
